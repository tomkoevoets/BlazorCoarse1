<div class="row mb-3">
    <div class="col-2">
        <label class="col-form-label">@label</label>
    </div>
    <div class="col-6 input-width">
        @Control
    </div>
    <div class="col">
        @ValidationControl
    </div>
</div>

@code {

	[Parameter]
	public string? label { get; set; }

	[Parameter]
	public RenderFragment? Control { get; set; }
    
    [Parameter]
	public RenderFragment? ValidationControl { get; set; }

}
